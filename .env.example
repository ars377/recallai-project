# Recall.ai
RECALL_API_KEY=replace_with_your_recall_api_key
RECALL_REGION=us-west-2

# Anthropic Claude
ANTHROPIC_API_KEY=replace_with_your_anthropic_api_key

# Optional: set after connecting Calendar V2.
# If omitted, scripts read .recall_calendar.json.
RECALL_CALENDAR_ID=

# Optional: public webhook URL for Calendar V2, usually from ngrok/cloudflared.
# Example: https://abc123.ngrok-free.app/webhooks/recall/calendar
RECALL_CALENDAR_WEBHOOK_URL=
